{
    // 如果你希望修改 pom.xml 后自动更新而不再弹窗烦人，可以改为 "automatic"
    "java.configuration.updateBuildConfiguration": "automatic",
    
    // 优化后的 JVM 参数 (JDK 21使用 ZGC)
    "java.jdt.ls.vmargs": "-XX:+UseZGC -XX:+ZGenerational -Dsun.zip.disableMemoryMapping=true -Xmx2G -Xms521m -Xlog:disable",

    // 在 IDE 中直接运行/调试时启用 JavaFX 本地访问，消除启动时的本地访问警告
    "java.debug.settings.vmArgs": "--enable-native-access=javafx.graphics"
}